generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id               String            @id @default(cuid())
  fullName         String
  email            String            @unique
  password         String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  quizzes          Quiz[]
  studyPlans       StudyPlan[]
  summaries        Summary[]
  tutoringSessions TutoringSession[]
}

model StudyPlan {
  id        String   @id @default(cuid())
  title     String
  goal      String
  deadline  DateTime
  progress  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model Summary {
  id         String   @id @default(cuid())
  title      String
  content    String
  sourceType String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model Quiz {
  id         String   @id @default(cuid())
  title      String
  difficulty String
  subject    String
  score      Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model TutoringSession {
  id           String    @id @default(cuid())
  topic        String
  notes        String
  status       String    @default("scheduled")
  scheduledFor DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  studentId    String
  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}
